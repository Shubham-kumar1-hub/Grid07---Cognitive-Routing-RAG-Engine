# --------------------------------------------
.cache/
~/.cache/huggingface/
sentence_transformers_cache/
models/

# --------------------------------------------
# LangChain / LangGraph Cache
# --------------------------------------------
.langchain.db
langchain_cache/

# --------------------------------------------
# Jupyter Notebooks
# --------------------------------------------
.ipynb_checkpoints/
*.ipynb

# --------------------------------------------
# Logs & Output Files
# --------------------------------------------
*.log
logs/
output/

