# --------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.pycache

# --------------------------------------------
# Virtual Environment
# --------------------------------------------
venv/
.venv/
env/
ENV/
.Python

# --------------------------------------------
# FAISS Index Files
# --------------------------------------------
*.index
*.faiss
faiss_store/

# --------------------------------------------
